// --- Tables Definitions ---

Table Customer {
  Id uuid [pk]
  Name varchar
  PhoneNumber varchar
  Email varchar
  CreatedAtUtc datetime
  CreatedBy varchar
  LastModifiedUtc datetime
  LastModifiedBy varchar
}

Table CustomerAddress {
  Id uuid [pk]
  CustomerId uuid
  Label varchar
  Street varchar
  City varchar
  Country varchar
  IsDefault bool
}

Table Category {
  Id uuid [pk]
  CategoryName varchar
  TaxRate decimal
}

Table Product {
  Id uuid [pk]
  ProductName varchar
  CategoryId uuid
  SupplierId uuid
  Description text
  Price decimal
  QuantityInStock int
  IsDeleted bool
  CreatedAtUtc datetime
  CreatedBy varchar
  LastModifiedUtc datetime
  LastModifiedBy varchar
}

Table ProductImage {
  Id uuid [pk]
  ProductId uuid
  ImageUrl varchar
  IsPrimary bool
}

Table ProductVariant {
  Id uuid [pk]
  ProductId uuid
  RAM varchar
  Storage varchar
  PriceModifier decimal
  QuantityInStock int
}

Table Supplier {
  Id uuid [pk]
  SupplierName varchar
  Phone varchar
}

Table Tag {
  Id uuid [pk]
  TagName varchar
}

Table ProductTag {
  Id uuid [pk]
  ProductId uuid
  TagId uuid
}

Table Order {
  Id uuid [pk]
  CustomerId uuid
  ShipperId uuid
  AddressId uuid
  StatusCode varchar
  CouponId uuid
  TotalAmount decimal
  DiscountAmount decimal
  CreatedAtUtc datetime
  CreatedBy varchar
  LastModifiedUtc datetime
  LastModifiedBy varchar
}

Table OrderItem {
  Id uuid [pk]
  OrderId uuid
  ProductId uuid
  UnitPrice decimal
  Quantity int
  Discount decimal
}

Table OrderStatus {
  Id uuid [pk]
  StatusCode varchar [unique, note: 'Primary Key logic or Unique Identifier']
  Label varchar
  SortOrder int
}

Table Payment {
  Id uuid [pk]
  OrderId uuid
  Amount decimal
  Method varchar
  PaymentDate datetime
  TransactionId varchar
  Status varchar
  CreatedAtUtc datetime
  CreatedBy varchar
  LastModifiedUtc datetime
  LastModifiedBy varchar
}

Table Shipper {
  Id uuid [pk]
  ShipperName varchar
}

Table Coupon {
  Id uuid [pk]
  Code varchar
  DiscountType varchar
  DiscountValue decimal
  ExpiresAtUtc datetime
  IsActive bool
  CreatedAtUtc datetime
  CreatedBy varchar
  LastModifiedUtc datetime
  LastModifiedBy varchar
}

Table Review {
  Id uuid [pk]
  ProductId uuid
  CustomerId uuid
  Rating byte
  Body text
  CreatedAtUtc datetime
  CreatedBy varchar
  LastModifiedUtc datetime
  LastModifiedBy varchar
}

Table Wishlist {
  Id uuid [pk]
  CustomerId uuid
  ProductId uuid
  AddedAt datetime
}

// --- Relationships (Foreign Keys) ---

// Auth & Profile
Ref: Customer.Id < CustomerAddress.CustomerId
Ref: CustomerAddress.Id < Order.AddressId

// Catalog
Ref: Category.Id < Product.CategoryId
Ref: Supplier.Id < Product.SupplierId
Ref: Product.Id < ProductImage.ProductId
Ref: Product.Id < ProductVariant.ProductId
Ref: Product.Id < ProductTag.ProductId
Ref: Tag.Id < ProductTag.TagId

// Orders
Ref: Customer.Id < Order.CustomerId
Ref: Shipper.Id < Order.ShipperId
Ref: Order.Id < OrderItem.OrderId
Ref: Product.Id < OrderItem.ProductId
Ref: Order.Id - Payment.OrderId // One-to-one or One-to-many
Ref: Coupon.Id < Order.CouponId
Ref: OrderStatus.StatusCode < Order.StatusCode

// Social
Ref: Product.Id < Review.ProductId
Ref: Customer.Id < Review.CustomerId
Ref: Product.Id < Wishlist.ProductId
Ref: Customer.Id < Wishlist.CustomerId